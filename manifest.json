{
  "name": "Alt Audit",
  "description": "San a webpage for images and get a report on all of the alt text found, and recommendations for improvements.",
  "version": "1.6.1",
  "manifest_version": 3,
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "/images/alt-audit16.png",
      "32": "/images/alt-audit32.png",
      "48": "/images/alt-audit48.png",
      "128": "/images/alt-audit128.png"
    }
  },
  "icons": {
    "16": "/images/alt-audit16.png",
    "32": "/images/alt-audit32.png",
    "48": "/images/alt-audit48.png",
    "128": "/images/alt-audit128.png"
  }
}
